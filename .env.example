# Скопируй этот файл в .env и заполни свои значения
# cp .env.example .env

# YouGile API — Bearer токен
YOUGILE_API_KEY=your_yougile_api_key_here

# Telegram Bot — токен от @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OpenRouter API — https://openrouter.ai/keys (чат, задачи, аудио)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenAI API (опционально, для Knowledge Base Sync)
# OPENAI_API_KEY=your_openai_api_key_here

# Timezone (для корректных дат в логах и дедлайнах)
TZ=Europe/Moscow
