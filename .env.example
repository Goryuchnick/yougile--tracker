# Скопируй этот файл в .env и заполни свои значения
# cp .env.example .env

# YouGile API — Bearer токен
YOUGILE_API_KEY=your_yougile_api_key_here

# Вторая компания (Welcome): дубль каждой созданной в боте задачи (заголовок, описание, дедлайн; без стикеров)
# YOUGILE_API_KEY_WELCOME=
# Либо UUID доски: YOUGILE_WELCOME_BOARD_ID=...
# Либо точные названия (если BOARD_ID не задан):
# YOUGILE_WELCOME_PROJECT=Маркетинг
# YOUGILE_WELCOME_BOARD=Онлайн-маркетинг
# YOUGILE_WELCOME_COLUMN=Надо сделать
# Префикс в описании копии (по умолчанию «[Дубль]»)
# YOUGILE_WELCOME_DESC_PREFIX=[Дубль]

# Дефолтный проект/доска для списков, отчётов и приоритизации (точное имя как в YouGile)
# YOUGILE_DEFAULT_PROJECT=Продуктивность
# YOUGILE_DEFAULT_BOARD=Задачи лог

# Колонки для «Активные задачи» и фильтров приоритизации (через запятую)
# YOUGILE_ACTIVE_COLUMNS=Надо сделать,В работе,На согласовании

# Колонки для AI-приоритизации (через запятую)
# YOUGILE_PRIORITY_AI_COLUMNS=Надо сделать,Бэклог,Входящие,В работе

# Пагинация GET /task-list (limit до 1000, несколько страниц)
# YOUGILE_TASK_LIST_LIMIT=200
# YOUGILE_TASK_LIST_MAX_PAGES=5

# Нарезка длинных HTML-сообщений Telegram
# TELEGRAM_HTML_CHUNK=4000

# Telegram Bot — токен от @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OpenRouter API — https://openrouter.ai/keys (чат, задачи, аудио)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Webhook URL (для регистрации webhooks в YouGile)
# WEBHOOK_URL=https://your-domain.com/webhook

# Timezone (для корректных дат в логах и дедлайнах)
TZ=Europe/Moscow
